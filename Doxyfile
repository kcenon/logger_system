# Doxyfile for logger_system

PROJECT_NAME           = "Logger System"
PROJECT_NUMBER         = "0.1.3"
PROJECT_BRIEF          = "High-performance C++20 thread-safe logging system with asynchronous capabilities"
OUTPUT_DIRECTORY       = documents
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
QUIET                  = NO
RECURSIVE              = YES
CASE_SENSE_NAMES       = SYSTEM
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        =
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE =
INLINE_SOURCES         = YES
CREATE_SUBDIRS         = NO
SOURCE_BROWSER         = YES
GENERATE_TREEVIEW      = YES
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = png
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
UML_LOOK               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
INTERACTIVE_SVG        = NO
DOT_PATH               =

# Enhanced documentation settings
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
BUILTIN_STL_SUPPORT    = YES
AUTOLINK_SUPPORT       = YES

# Preprocessor settings
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = sources
PREDEFINED             = USE_THREAD_SYSTEM
ALIASES                = "thread_safety=@par Thread Safety:^^" \
                         "performance=@par Performance:^^"

# Warning settings
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"

# Example settings
EXAMPLE_PATH           = examples
EXAMPLE_PATTERNS       = *.cpp *.h
EXAMPLE_RECURSIVE      = YES

# Source browsing
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
SOURCE_TOOLTIPS        = YES
VERBATIM_HEADERS       = YES

# Alphabetical index
ALPHABETICAL_INDEX     = YES
COLS_IN_ALPHA_INDEX    = 5

INPUT                  = README.md ARCHITECTURE.md SECURITY.md \
                         include/kcenon/logger \
                         src \
                         docs \
                         ./examples
FILE_PATTERNS          = *.c \
                         *.cc \
                         *.cxx \
                         *.cpp \
                         *.cppm \
                         *.h \
                         *.hh \
                         *.hpp \
                         *.tpp \
                         *.md \
                         *.dox
EXCLUDE                = ./build \
                         ./build_test \
                         ./vcpkg \
                         ./vcpkg_installed \
                         ./documents
EXCLUDE_PATTERNS       = */CMakeFiles/* \
                         */.git/* \
                         */build*/* \
                         */vcpkg*/* \
                         */_deps/* \
                         */node_modules/*
HTML_OUTPUT            = html
HTML_HEADER            = docs/header.html
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome-css/doxygen-awesome.css \
                         docs/doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
                         docs/custom.css
HTML_EXTRA_FILES       = docs/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         docs/doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         docs/doxygen-awesome-css/doxygen-awesome-paragraph-link.js \
                         docs/doxygen-awesome-css/doxygen-awesome-interactive-toc.js
HTML_COPY_CLIPBOARD    = NO
HTML_COLORSTYLE        = LIGHT
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_CODE_FOLDING      = YES
FULL_SIDEBAR           = NO
HTML_TIMESTAMP         = NO
TIMESTAMP              = NO

